<article class="demo-card" data-demo-id="{{ demo.id | escape }}">
  <div class="card-topline">
    <span class="status status-{{ demo.status }}">{{ demo.status | statusLabel }}</span>
    <span class="demo-id">{{ demo.id | escape }}</span>
  </div>
  <h3>{{ demo.title | escape }}</h3>
  <p class="author">by {{ demo.author | escape }}</p>
  <p class="tagline">{{ demo.tagline | escape }}</p>
  {% if demo.origin_idea %}
  <p class="origin">源自灵感 #{{ demo.origin_idea | escape }}</p>
  {% endif %}
  <div class="card-actions">
    {% if demo.demo_url %}<a href="{{ demo.demo_url | escape }}" data-demo-link="demo" target="_blank" rel="noopener noreferrer">打开 Demo</a>{% endif %}
    {% if demo.repo_url %}<a href="{{ demo.repo_url | escape }}" data-demo-link="repo" target="_blank" rel="noopener noreferrer">查看仓库</a>{% endif %}
    {% if demo.issue_url %}<a href="{{ demo.issue_url | escape }}" data-demo-link="issue" target="_blank" rel="noopener noreferrer">项目记录</a>{% endif %}
  </div>
</article>
